# Stripe Price IDs (from Products)
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_YEARLY_PRICE_ID=price_...

# Frontend URL (for CORS and Stripe redirects)
FRONTEND_URL=http://localhost:5173
